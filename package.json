{
  "name": "simple-ascii-chart-website",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "docs:generate": "node scripts/generate-settings-docs.mjs",
    "docs:check": "node scripts/generate-settings-docs.mjs --check",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/**/*.test.mjs",
    "build": "yarn docs:generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "deploy": "yarn add simple-ascii-chart --upgrade && git add . && git commit -m'ascii-website: Bump version' && git push -u origin main"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "highlight.js": "^11.11.1",
    "monaco-editor": "^0.55.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "simple-ascii-chart": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "eslint": "9.39.0",
    "eslint-config-next": "16.2.2",
    "typescript": "6.0.2"
  },
  "resolutions": {
    "@typescript-eslint/typescript-estree/minimatch/brace-expansion": "5.0.5",
    "eslint/@eslint/config-array/minimatch": "3.1.5",
    "eslint/file-entry-cache/flat-cache/flatted": "3.4.2",
    "eslint/minimatch": "3.1.5",
    "eslint-config-next/@next/eslint-plugin-next/fast-glob/micromatch/picomatch": "2.3.2",
    "eslint-config-next/eslint-plugin-import/minimatch": "3.1.5",
    "eslint-config-next/eslint-plugin-jsx-a11y/minimatch": "3.1.5",
    "eslint-config-next/eslint-plugin-react/minimatch": "3.1.5",
    "minimatch/brace-expansion": "1.1.13",
    "monaco-editor/dompurify": "3.3.2",
    "next/postcss/nanoid": "3.3.8"
  }
}
